APP_NAME="Feiwellhub Naturals"
APP_ENV=production
APP_KEY=                              # Auto-generated by Render
APP_DEBUG=false
APP_URL=https://feiwellhub-api.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-password
DB_SSLMODE=require


REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_SCHEME=tls

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ── Auth / CORS ───────────────────────────────────────
# Add your Cloudflare Pages URL after first deploy
SANCTUM_STATEFUL_DOMAINS=feiwellhub.pages.dev,feiwellhub.co.ke
CORS_ALLOWED_ORIGINS=https://feiwellhub.pages.dev,https://feiwellhub.co.ke
SESSION_DOMAIN=.feiwellhub.co.ke
