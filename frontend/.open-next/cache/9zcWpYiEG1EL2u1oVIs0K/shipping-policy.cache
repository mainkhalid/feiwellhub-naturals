,[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Delivery fee:\"}],\" Ksh 200 flat rate. \",[\"$\",\"strong\",null,{\"children\":\"Free delivery\"}],\" on orders above Ksh 2,000.\"]}],[\"$\",\"h3\",null,{\"children\":\"Outside Nairobi (Courier Delivery)\"}],[\"$\",\"p\",null,{\"children\":\"For orders outside Nairobi, we use trusted courier partners (G4S, Well Fargo, DHL). Delivery timelines:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Major towns (Mombasa, Kisumu, Nakuru, Eldoret): 1–2 business days\"}],[\"$\",\"li\",null,{\"children\":\"Other towns: 2–4 business days\"}]]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Courier fee:\"}],\" Calculated based on destination and package weight. We'll confirm the fee before you pay.\"]}],[\"$\",\"h2\",null,{\"children\":\"Order Processing\"}],[\"$\",\"p\",null,{\"children\":\"Orders placed via WhatsApp are processed within 1–2 hours during business hours. You'll receive a confirmation message with your order details and delivery timeline.\"}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Business hours:\"}],\" \",\"Nairobi, Kenya\",\" — Monday to Friday 8am–6pm, Saturday 9am–4pm.\"]}],[\"$\",\"h2\",null,{\"children\":\"Failed Delivery\"}],[\"$\",\"p\",null,{\"children\":\"If a delivery attempt fails because you are unavailable, our rider will contact you to reschedule. A redelivery fee may apply for subsequent attempts.\"}],[\"$\",\"h2\",null,{\"children\":\"Tracking Your Order\"}],[\"$\",\"p\",null,{\"children\":\"Our rider will contact you directly via phone/WhatsApp when they are on the way. For courier shipments outside Nairobi, we'll share a tracking number once your package is dispatched.\"}],[\"$\",\"h2\",null,{\"children\":\"Questions?\"}],[\"$\",\"p\",null,{\"children\":[\"Contact us on \",[\"$\",\"a\",null,{\"href\":\"tel:+254 715 945 238\",\"className\":\"text-sage hover:underline\",\"children\":\"+254 715