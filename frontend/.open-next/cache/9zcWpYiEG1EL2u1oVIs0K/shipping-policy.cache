ass=\"hidden lg:flex items-center gap-0.5 flex-1 justify-center\"><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/products\">All Products</a></div><div class=\"relative\"><button class=\"flex items-center gap-1 px-3.5 py-2 text-[0.875rem] font-medium\n                    rounded-lg transition-all duration-150\n                    text-text-main hover:text-sage hover:bg-sage-pale\" aria-expanded=\"false\">By Condition<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\n                    text-text-muted\"><path d=\"m6 9 6 6 6-6\"></path></svg></button></div><div class=\"relative\"><button class=\"flex items-center gap-1 px-3.5 py-2 text-[0.875rem] font-medium\n                    rounded-lg transition-all duration-150\n                    text-text-main hover:text-sage hover:bg-sage-pale\" aria-expanded=\"false\">By Supplement<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\n                    text-text-muted\"><path d=\"m6 9 6 6 6-6\"></path></svg></button></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/products?category=immune-support\">Immune Support</a></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/about\">About Us</a></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/contact\">Contact</a></div></nav><div class=\"flex items-center gap-2 shrink-0\"><a class=\"hidden lg:inline-flex btn btn-primary btn-sm text-xs px-5\" href=\"/contact\">Get Advice</a><button class=\"lg:hidden p-2 rounded-lg text-bark hover:bg-gray-100 transition-colors\" aria-label=\"Toggle menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></div></header><main><section class=\"bg-white border-b border-gray-100 py-14\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto\"><span class=\"section-label block mb-2\">Policies</span><h1 class=\"text-bark\">Shipping &amp; Delivery Policy</h1><p class=\"text-text-muted text-sm mt-2\">Last updated: January 2025</p></div></section><section class=\"py-14\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto max-w-[800px]\"><div class=\"grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12\"><div class=\"bg-cream rounded-2xl p-5 border border-gray-100 text-center\"><div class=\"w-10 h-10 bg-sage-pale rounded-xl flex items-center justify-center text-sage mx-auto mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg></div><p class=\"text-xs font-semibold tracking-wider uppercase text-text-muted mb-1\">Delivery Fee</p><p class=\"text-sm font-medium text-bark\">Ksh 200 (free above Ksh 2,000)</p></div><div class=\"bg-cream rounded-2xl p-5 border border-gray-100 text-center\"><div class=\"w-10 h-10 bg-sage-pale rounded-xl flex items-center justify-center text-sage mx-auto mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg></div><p class=\"text-xs font-semibold tracking-wider uppercase text-text-muted mb-1\">Same-Day</p><p class=\"text-sm font-medium text-bark\">Orders before 2pm, Mon–Sat</p></div><div class=\"bg-cream rounded-2xl p-5 border border-gray-100 text-center\"><div class=\"w-10 h-10 bg-sage-pale rounded-xl flex items-center justify-center text-sage mx-auto mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg></div><p class=\"text-xs font-semibold tracking-wider uppercase text-text-muted mb-1\">Coverage</p><p class=\"text-sm font-medium text-bark\">Nairobi + nationwide courier</p></div></div><div class=\"prose prose-sm max-w-none text-text-muted leading-relaxed [&amp;_h2]:font-display [&amp;_h2]:text-2xl [&amp;_h2]:text-bark [&amp;_h2]:mt-10 [&amp;_h2]:mb-4 [&amp;_h3]:font-semibold [&amp;_h3]:text-bark [&amp;_h3]:mt-6 [&amp;_h3]:mb-2 [&amp;_ul]:list-disc [&amp;_ul]:pl-5 [&amp;_ul]:flex [&amp;_ul]:flex-col [&amp;_ul]:gap-1.5 [&amp;_p]:mb-4 [&amp;_strong]:text-bark [&amp;_strong]:font-semibold\"><h2>Delivery Areas &amp; Fees</h2><h3>Nairobi (Same-Day Delivery)</h3><p>We offer same-day delivery to the following Nairobi areas for orders placed before 2:00pm Monday to Saturday:</p><ul><li>Nairobi CBD &amp; surrounding areas</li><li>Westlands, Parklands, Riverside</li><li>Kilimani, Lavington, Hurlingham</li><li>Karen, Langata, Rongai</li><li>Kasarani, Roysambu, Thika Road</li><li>Embakasi, South B, South C</li><li>Eastlands (Buruburu, Donholm, Umoja)</li></ul><p><strong>Delivery fee:</strong> Ksh 200 flat rate. <strong>Free delivery</strong> on orders above Ksh 2,000.</p><h3>Outside Nairobi (Courier Delivery)</h3><p>For orders outside Nairobi, we use trusted courier partners (G4S, Well Fargo, DHL). Delivery timelines:</p><ul><li>Major towns (Mombasa, Kisumu, Nakuru, Eldoret): 1–2 business days</li><li>Other towns: 2–4 business days</li></ul><p><strong>Courier fee:</strong> Calculated based on destination and package weight. We&#x27;ll confirm the fee before you pay.</p><h2>Order Processing</h2><p>Orders placed via WhatsApp are processed within 1–2 hours during business hours. You&#x27;ll receive a confirmation message with your order details and delivery timeline.</p><p><strong>Business hours:</strong> <!-- -->Nairobi, Kenya<!-- --> — Monday to Friday 8am–6pm, Saturday 9am–4pm.</p><h2>Failed Delivery</h2><p>If a delivery attempt fails because you are unavailable, our rider will contact you to reschedule. A redelivery fee may apply for subsequent attempts.</p><h2>Tracking Your Order</h2><p>Our rider will contact you directly via phone/WhatsApp when they are on the way. For courier shipments outside Nairobi, we&#x27;ll share a tracking number once your package is dispatched.</p><h2>Questions?</h2><p>Contact us on <a href=\"tel:+254 715 945 238\" class=\"text-sage hover:underline\">+254 715 945 238</a> or<!-- --> <a class=\"text-sage hover:underline\" href=\"/contact\">send us a message</a>.</p></div><div class=\"mt-10 p-5 bg-cream rounded-2xl border border-gray-100 flex gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-alert text-sage shrink-0 mt-0.5\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" x2=\"12\" y1=\"8\" y2=\"12\"></line><line x1=\"12\" x2=\"12.01\" y1=\"16\" y2=\"16\"></line></svg><p class=\"text-sm text-text-muted\">Delivery timelines may be affected by public holidays, severe weather or high demand periods. We&#x27;ll always communicate any delays as soon as possible.</p></div></div></section></main><footer class=\"bg-bark text-cream\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto pt-16 pb-10\"><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1fr_1fr_1.4fr] gap-10 pb-10 border-b border-cream/10\"><div><div class=\"flex items-center gap-3 mb-4\"><div class=\"flex items-center justify-center\"><img alt=\"Feiwellhub Naturals\" loading=\"lazy\" width=\"82\" height=\"72\" decoding=\"async\" data-nimg=\"1\" class=\" object-contain brightness-0 invert sepia-[30%] saturate-[400%] hue-rotate-[10deg]\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=96&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=256&amp;q=75\"/></div><div class=\"leading-tight\"><span class=\"font-display text-lg font-semibold text-cream block tracking-wide\">Feiwellhub</span><span class=\"text-[0.6rem] tracking-[0.22em] uppercase text-cream/40 block mt-0.5\">Naturals</span></div></div><p class=\"text-