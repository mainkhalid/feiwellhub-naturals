roperty=\"og:site_name\" content=\"Feiwellhub Naturals\"/><meta property=\"og:locale\" content=\"en_KE\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Feiwellhub Naturals\"/><meta name=\"twitter:description\" content=\"Premium food supplements and herbal wellness products.\"/><link rel=\"icon\" href=\"/icon.png?2b67a4683078cab6\" type=\"image/png\" sizes=\"500x500\"/><link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><header class=\"sticky top-0 z-50 bg-white transition-all duration-200\n      border-b border-gray-100\"><div class=\"bg-sage text-white text-center text-xs py-2 px-4 font-body font-medium tracking-wide\">🌿 Free delivery on orders above Ksh 2,000  ·  Consult our wellness team before use  ·  Same-day Nairobi delivery</div><div class=\"w-[min(1280px,100%-2rem)] mx-auto flex items-center justify-between h-16 gap-4\"><a class=\"flex items-center gap-2.5 shrink-0\" aria-label=\"Feiwellhub Naturals home\" href=\"/\"><img alt=\"Feiwellhub Naturals\" loading=\"lazy\" width=\"60\" height=\"50\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=64&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=128&amp;q=75 2x\" src=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=128&amp;q=75\"/><div class=\"leading-none\"><span class=\"font-display text-[1.3rem] font-semibold text-bark block tracking-tight\">Feiwellhub</span><span class=\"text-[0.6rem] tracking-[0.2em] uppercase text-sage font-body\">Naturals</span></div></a><nav class=\"hidden lg:flex items-center gap-0.5 flex-1 justify-center\"><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/products\">All Products</a></div><div class=\"relative\"><button class=\"flex items-center gap-1 px-3.5 py-2 text-[0.875rem] font-medium\n                    rounded-lg transition-all duration-150\n                    text-text-main hover:text-sage hover:bg-sage-pale\" aria-expanded=\"false\">By Condition<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\n                    text-text-muted\"><path d=\"m6 9 6 6 6-6\"></path></svg></button></div><div class=\"relative\"><button class=\"flex items-center gap-1 px-3.5 py-2 text-[0.875rem] font-medium\n                    rounded-lg transition-all duration-150\n                    text-text-main hover:text-sage hover:bg-sage-pale\" aria-expanded=\"false\">By Supplement<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\n                    text-text-muted\"><path d=\"m6 9 6 6 6-6\"></path></svg></button></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/products?category=immune-support\">Immune Support</a></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/about\">About Us</a></div><div class=\"relative\"><a class=\"px-3.5 py-2 text-[0.875rem] font-medium rounded-lg\n                    transition-all duration-150 block\n                    text-text-main hover:text-sage hover:bg-sage-pale\" href=\"/contact\">Contact</a></div></nav><div class=\"flex items-center gap-2 shrink-0\"><a class=\"hidden lg:inline-flex btn btn-primary btn-sm text-xs px-5\" href=\"/contact\">Get Advice</a><button class=\"lg:hidden p-2 rounded-lg text-bark hover:bg-gray-100 transition-colors\" aria-label=\"Toggle menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></div></header><main><section class=\"bg-sage py-24\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto text-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf text-white/60 mx-auto mb-5\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg><span class=\"section-label text-white/70 block mb-3\">Our commitment</span><h1 class=\"text-white mb-5\" style=\"font-size:clamp(2rem,5vw,3.2rem)\">Good for you.<br/>Good for the planet.</h1><p class=\"text-white/75 max-w-[560px] mx-auto text-lg font-light leading-relaxed\">Sustainability isn&#x27;t a marketing angle for us — it&#x27;s a core operating principle. Here&#x27;s exactly what we do and how we measure it.</p></div></section><section class=\"py-20 bg-white\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">100%</div><div class=\"text-xs text-text-muted\">traceable ingredients</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Ethical Sourcing</h3><p class=\"text-sm text-text-muted leading-relaxed\">We work directly with certified organic farms across Kenya and East Africa. No mystery supply chains — we visit our suppliers, pay fair prices, and build long-term relationships.</p></div><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-recycle\"><path d=\"M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5\"></path><path d=\"M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12\"></path><path d=\"m14 16-3 3 3 3\"></path><path d=\"M8.293 13.596 7.196 9.5 3.1 10.598\"></path><path d=\"m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843\"></path><path d=\"m13.378 9.633 4.096 1.098 1.097-4.096\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">80%</div><div class=\"text-xs text-text-muted\">recyclable packaging</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Eco Packaging</h3><p class=\"text-sm text-text-muted leading-relaxed\">Our packaging uses recycled paper labels, glass bottles where possible, and compostable seals. We are actively working to eliminate single-use plastics from our supply chain by 2026.</p></div><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">70%</div><div class=\"text-xs text-text-muted\">locally sourced</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Supporting Local</h3><p class=\"text-sm text-text-muted leading-relaxed\">Every shilling we spend on ingredients stays in Kenya where possible. Supporting local farmers means supporting local economies and reducing the carbon footprint of imports.</p></div><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-droplets\"><path d=\"M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z\"></path><path d=\"M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">0</div><div class=\"text-xs text-text-muted\">synthetic solvents used</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Minimal Processing</h3><p class=\"text-sm text-text-muted leading-relaxed\">We use cold-pressing, low-temperature drying and gentle extraction methods that preserve nutrient integrity and use less energy than industrial processing.</p></div><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">100%</div><div class=\"text-xs text-text-muted\">fair-pay certified partners</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Fair Labour</h3><p class=\"text-sm text-text-muted leading-relaxed\">We ensure everyone in our supply chain is paid fairly and works in safe conditions. This is non-negotiable — we audit our partners annually.</p></div><div class=\"bg-cream rounded-2xl p-7 border border-gray-100 hover:border-sage/20 hover:shadow-md transition-all duration-200\"><div class=\"flex items-start justify-between mb-5\"><div class=\"w-11 h-11 bg-sage-pale rounded-xl flex items-center justify-center text-sage\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><div class=\"text-right\"><div class=\"font-display text-2xl font-semibold text-sage\">0</div><div class=\"text-xs text-text-muted\">synthetic pesticides</div></div></div><h3 class=\"font-display text-xl text-bark mb-2\">Biodiversity</h3><p class=\"text-sm text-text-muted leading-relaxed\">We only source from farms practising regenerative agriculture. This means crop rotation, companion planting and no chemical pesticides — protecting the soil for future generations.</p></div></div></div></section><section class=\"py-20 bg-cream-dark\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto max-w-[700px]\"><div class=\"text-center mb-12\"><span class=\"section-label block mb-2\">Where we&#x27;re heading</span><h2 class=\"text-bark\">2025–2027 Sustainability Roadmap</h2></div><div class=\"flex flex-col gap-5\"><div class=\"flex gap-5 items-start bg-white rounded-xl p-5 border border-gray-100\"><div class=\"bg-sage text-white text-sm font-bold px-3 py-1.5 rounded-lg shrink-0\">2025</div><p class=\"text-sm text-text-muted leading-relaxed pt-0.5\">Achieve 100% plastic-free primary packaging across all product lines.</p></div><div class=\"flex gap-5 items-start bg-white rounded-xl p-5 border border-gray-100\"><div class=\"bg-sage text-white text-sm font-bold px-3 py-1.5 rounded-lg shrink-0\">2026</div><p class=\"text-sm text-text-muted leading-relaxed pt-0.5\">Partner exclusively with farms holding organic certification.</p></div><div class=\"flex gap-5 items-start bg-white rounded-xl p-5 border border-gray-100\"><div class=\"bg-sage text-white text-sm font-bold px-3 py-1.5 rounded-lg shrink-0\">2027</div><p class=\"text-sm text-text-muted leading-relaxed pt-0.5\">Achieve carbon-neutral delivery operations in Nairobi.</p></div></div></div></section></main><footer class=\"bg-bark text-cream\"><div class=\"w-[min(1280px,100%-2rem)] mx-auto pt-16 pb-10\"><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1fr_1fr_1.4fr] gap-10 pb-10 border-b border-cream/10\"><div><div class=\"flex items-center gap-3 mb-4\"><div class=\"flex items-center justify-center\"><img alt=\"Feiwellhub Naturals\" loading=\"lazy\" width=\"82\" height=\"72\" decoding=\"async\" data-nimg=\"1\" class=\" object-contain brightness-0 invert sepia-[30%] saturate-[400%] hue-rotate-[10deg]\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=96&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ffeiwell-logo.94ea443d.png&amp;w=256&amp;q=75\"/></div><div class=\"leading-tight\"><span class=\"font-display text-lg font-semibold text-cream block tracking-wide\">Feiwellhub</span><span class=\"text-[0.6rem] tracking-[0.22em] uppercase text-cream/40 block mt-0.5\">Naturals</span></div></div><p class=\"te