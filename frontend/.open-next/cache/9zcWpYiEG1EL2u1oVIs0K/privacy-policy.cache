ldren\":[[\"$\",\"h2\",null,{\"children\":\"1. Who We Are\"}],[\"$\",\"p\",null,{\"children\":[\"Feiwellhub Naturals\",\" is a natural wellness company based in \",\"Nairobi, Kenya\",\". For privacy-related queries, contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:sales@feiwellhub.co.ke\",\"className\":\"text-sage hover:underline\",\"children\":\"sales@feiwellhub.co.ke\"}],\".\"]}],[\"$\",\"h2\",null,{\"children\":\"2. Information We Collect\"}],[\"$\",\"h3\",null,{\"children\":\"Information you provide directly\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Name, phone number and email address when placing an order or contacting us\"}],[\"$\",\"li\",null,{\"children\":\"Delivery address for order fulfilment\"}],[\"$\",\"li\",null,{\"children\":\"Messages and enquiries submitted via our contact form or WhatsApp\"}]]}],[\"$\",\"h3\",null,{\"children\":\"Information collected automatically\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Browser type and device information when you visit our website\"}],[\"$\",\"li\",null,{\"children\":\"Pages visited and time spent on the site (via anonymous analytics)\"}],[\"$\",\"li\",null,{\"children\":\"IP address for security and fraud prevention\"}]]}],[\"$\",\"h2\",null,{\"children\":\"3. How We Use Your Information\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"To process and fulfil your orders\"}],[\"$\",\"li\",null,{\"children\":\"To communicate with you about your order status\"}],[\"$\",\"li\",null,{\"children\":\"To respond to enquiries and provide customer support\"}],[\"$\",\"li\",null,{\"children\":\"To send occasional product updates (only if you opt in)\"}],[\"$\",\"li\",null,{\"children\":\"To improve our website and product offerings\"}],[\"$\",\"li\",null,{\"children\":\"To comply with legal obligations\"}]]}],[\"$\",\"h2\",null,{\"children\":\"4. Who We Share Your Data With\"}],[\"$\",\"p\",null,{\"children\":\"We do not sell your personal data. We may share limited information with:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Delivery partners\"}],\" — your name, phone and address for order delivery\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Payment processors\"}],\" — M-Pesa/bank details are handled by Safaricom/your bank, not stored by us\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Legal authorities\"}],\" — if required by Kenyan law\"]}]]}],[\"$\",\"h2\",null,{\"children\":\"5. Data Retention\"}],[\"$\",\"p\",null,{\"children\":[\"We retain order and contact information for up to \",[\"$\",\"strong\",null,{\"children\":\"3 years\"}],\" for record-keeping purposes, or longer if required by law. You may request deletion of your data at any time (subject to legal retention requirements).\"]}],[\"$\",\"h2\",null,{\"children\":\"6. Your Rights\"}],[\"$\",\"p\",null,{\"children\":\"Under applicable Kenyan data protection law, you have the right to:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Access the personal data we hold about you\"}],[\"$\",\"li\",null,{\"children\":\"Request correction of inaccurate data\"}],[\"$\",\"li\",null,{\"children\":\"Request deletion of your data\"}],[\"$\",\"li\",null,{\"children\":\"Opt out of marketing communications at any time\"}],[\"$\",\"li\",null,{\"children\":\"Lodge a complaint with the Office of the Data Protection Commissioner (Kenya)\"}]]}],[\"$\",\"h2\",null,{\"children\":\"7. Cookies\"}],[\"$\",\"p\",null,{\"children\":\"Our website uses minimal cookies — only those necessary for the site to function correctly. We do not use third-party advertising cookies.\"}],[\"$\",\"h2\",null,{\"children\":\"8. Security\"}],[\"$\",\"p\",null,{\"children\":\"We use HTTPS encryption on all pages and follow security best practices to protect your data. However, no method of transmission over the internet is 100% secure.\"}],[\"$\",\"h2\",null,{\"children\":\"9. Changes to This Policy\"}],[\"$\",\"p\",null,{\"children\":\"We may update this policy from time to time. The date at the top of this page reflects the most recent update. Continued use of our website after changes constitutes acceptance.\"}],[\"$\",\"h2\",null,{\"children\":\"10. Contact Us\"}],[\"$\",\"p\",null,{\"children\":[\"For any privacy-related questions or to exercise your rights, contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:sales@feiwellhub.co.ke\",\"className\":\"text-sage hover:underline\",\"children\":\"sales@feiwellhub.co.ke\"}],\" \",\"or via our \",[\"$\",\"$L3\",null,{\"href\":\"/contact\",\"className\":\"text-sage hover:underline\",\"children\":\"contact form\"}],\".\"]}]]}]]}]}]]}],[\"$\",\"footer\",null,{\"className\":\"bg-bark text-cream\",\"children\":[\"$\",\"div\",null,{\"className\":\"w-[min(1280px,100%-2rem)] mx-auto pt-16 pb-10\",\"children\":[[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1fr_1fr_1.4fr] gap-10 pb-10 border-b border-cream/10\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-center\",\"children\":[\"$\",\"$L4\",null,{\"src\":{\"src\":\"/_next/static/media/feiwell-logo.94ea443d.png\",\"height\":500,\"width\":500,\"blurDataURL\":\"data:image/png;base64,\",\"blurWidth\":8,\"blurHeight\":8},\"alt\":\"Feiwellhub Naturals\",\"width\":82,\"height\":72,\"className\":\" object-contain brightness-0 invert sepia-[30%] saturate-[400%] hue-rotate-[10deg]\"}]}],[\"$\",\"div\",null,{\"className\":\"leading-tight\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-display text-lg font-semibold text-cream block tracking-wide\",\"children\":\"Feiwellhub\"}],[\"$\",\"span\",null,{\"className\":\"text-[0.6rem] tracking-[0.22em] uppercase text-cream/40 block mt-0.5\",\"ch